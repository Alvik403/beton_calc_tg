# Обязательно для веб-конфигуратора (не оставляйте пустым в проде)
CONFIG_PASSWORD=replace_with_long_random_secret

# Порт веб-интерфейса на хосте (docker). Если 8081 занят — например BETON_WEB_PORT=8090
# BETON_WEB_PORT=8081

# Лимит размера загружаемого .xlsx (МБ), по умолчанию 20
# MAX_UPLOAD_MB=20

# В Docker Compose профили веба на томе; локально без Docker можно не задавать (файлы в config/)
